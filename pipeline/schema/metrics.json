{
  "version": "1.0.0",
  "note": "Canonical metric taxonomy — the compiler IR. Funnel levels loosely align with the IMP five-dimensions 'Who/How Much' depth scale; org metrics align with common IRIS+ concepts (PI/OI series). Frozen 15:30 — additions ok, renames forbidden.",
  "metrics": [
    { "id": "funnel.inform", "type": "count", "unit": "people", "desc": "People who received education/information (funnel level 1)" },
    { "id": "funnel.inform.women_abs", "type": "count", "unit": "people", "desc": "Absolute number of women among people informed" },
    { "id": "funnel.inform.marginalised", "type": "text", "desc": "Who are the vulnerable/marginalised groups reached (level 1)" },
    { "id": "funnel.inform.methodology", "type": "text", "desc": "How the inform number was calculated" },
    { "id": "funnel.engage", "type": "count", "unit": "people", "desc": "People directly engaged in two-way interaction (funnel level 2)" },
    { "id": "funnel.engage.women_abs", "type": "count", "unit": "people", "desc": "Absolute number of women among people engaged" },
    { "id": "funnel.engage.marginalised", "type": "text", "desc": "Vulnerable/marginalised groups reached (level 2)" },
    { "id": "funnel.engage.methodology", "type": "text", "desc": "How the engage number was calculated" },
    { "id": "funnel.outcomes", "type": "count", "unit": "people", "desc": "People with immediate positive outcomes (funnel level 3)" },
    { "id": "funnel.outcomes.women_abs", "type": "count", "unit": "people", "desc": "Absolute number of women among outcomes level" },
    { "id": "funnel.outcomes.marginalised", "type": "text", "desc": "Vulnerable/marginalised groups reached (level 3)" },
    { "id": "funnel.outcomes.methodology", "type": "text", "desc": "How the outcomes number was calculated" },
    { "id": "funnel.impact", "type": "count", "unit": "people", "desc": "People with positive day-to-day life changes (funnel level 4)" },
    { "id": "funnel.impact.women_abs", "type": "count", "unit": "people", "desc": "Absolute number of women among impact level" },
    { "id": "funnel.impact.marginalised", "type": "text", "desc": "Vulnerable/marginalised groups reached (level 4)" },
    { "id": "funnel.impact.methodology", "type": "text", "desc": "How the impact number was calculated" },
    { "id": "funnel.societal", "type": "count", "unit": "people", "desc": "People with material societal impact (funnel level 5)" },
    { "id": "funnel.societal.women_abs", "type": "count", "unit": "people", "desc": "Absolute number of women among societal level" },
    { "id": "funnel.societal.marginalised", "type": "text", "desc": "Vulnerable/marginalised groups reached (level 5)" },
    { "id": "funnel.societal.methodology", "type": "text", "desc": "How the societal number was calculated" },
    { "id": "reach.beneficiaries", "type": "count", "unit": "people", "desc": "Total beneficiaries currently reached (generic reach question outside the funnel)" },
    { "id": "reach.beneficiaries.methodology", "type": "text", "desc": "How the beneficiary number was calculated / additional impact data shared" },
    { "id": "reach.women_pct", "type": "percent", "desc": "Share of women among beneficiaries" },
    { "id": "reach.marginalised_pct", "type": "percent", "desc": "Share of marginalised/vulnerable among beneficiaries" },
    { "id": "reach.customers", "type": "count", "unit": "customers", "desc": "Paying customers currently served" },
    { "id": "fin.revenue_monthly", "type": "money", "desc": "Average monthly revenue" },
    { "id": "fin.revenue_annual", "type": "money", "desc": "Annual revenue" },
    { "id": "fin.mrr", "type": "money", "desc": "Monthly recurring revenue" },
    { "id": "fin.ebitda", "type": "money", "desc": "EBITDA" },
    { "id": "fin.net_profit", "type": "money", "desc": "Net profit" },
    { "id": "fin.runway_months", "type": "months", "desc": "Runway in months (cash balance / monthly expenses)" },
    { "id": "fin.funding_total", "type": "money", "desc": "Total funding raised / current funding size" },
    { "id": "fin.funding_equity", "type": "money", "desc": "Equity funding raised" },
    { "id": "fin.funding_debt", "type": "money", "desc": "Debt funding raised" },
    { "id": "fin.funding_grants", "type": "money", "desc": "Grant funding raised" },
    { "id": "fin.funding_requirement", "type": "money", "desc": "Current funding requirement / ask" },
    { "id": "fin.valuation", "type": "money", "desc": "Company valuation" },
    { "id": "team.fte", "type": "count", "unit": "people", "desc": "Full-time employees" },
    { "id": "team.part_time", "type": "count", "unit": "people", "desc": "Part-time / contract jobs" },
    { "id": "prog.nps", "type": "score", "desc": "How likely to recommend the accelerator (0-10)" },
    { "id": "prog.attribution", "type": "score", "desc": "How much the accelerator influenced the business (0-10 or similar)" },
    { "id": "prog.impact_score", "type": "score", "desc": "How much the programme impacted you (0-10)" },
    { "id": "prog.module_rating_m1", "type": "score", "desc": "Rating of programme module 1" },
    { "id": "prog.module_rating_m2", "type": "score", "desc": "Rating of programme module 2" },
    { "id": "prog.module_rating_m3", "type": "score", "desc": "Rating of programme module 3" },
    { "id": "prog.module_rating_m4", "type": "score", "desc": "Rating of programme module 4" },
    { "id": "text.needs_top3", "type": "text", "desc": "Top 3 needs as an organisation" },
    { "id": "text.takeaway", "type": "text", "desc": "Biggest takeaway from the programme" },
    { "id": "text.improvement", "type": "text", "desc": "What could be improved about the programme" },
    { "id": "text.proud", "type": "text", "desc": "Milestones / achievements the org is proud of" },
    { "id": "text.impact_elaboration", "type": "text", "desc": "Free-text elaboration on programme impact" },
    { "id": "ctx.country", "type": "text", "desc": "Country of operation" },
    { "id": "ctx.legal_status", "type": "text", "desc": "Legal status / entity type" },
    { "id": "ctx.stage", "type": "text", "desc": "Business stage" }
  ],
  "capability_pattern": {
    "note": "K&B self-assessments (deferred files) map to cap.<competency>.<knowledge|behaviour>_<before|after>, type score.",
    "competencies": ["systems", "purpose", "imm", "customer", "design_thinking", "product_service", "business_strategy", "unit_economics", "leadership", "finance", "fundraising", "marketing", "operations"]
  }
}
